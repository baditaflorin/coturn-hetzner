# Your Hetzner server public IPv4 (find it in the Hetzner console)
SERVER_IP=1.2.3.4

# A domain pointing at your server, or just the IP if you skip TLS
TURN_DOMAIN=turn.yourdomain.com

# Shared secret used to validate HMAC credentials — must match TURN_SECRET
# in turn-token-server. Generate with: openssl rand -hex 32
# NEVER commit this value to git.
TURN_SECRET=change-me-generate-with-openssl-rand-hex-32
